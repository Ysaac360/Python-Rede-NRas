import random

class Personagem:
    def __init__(self, nome, classe, forca, defesa, vida):
        self.nome = nome
        self.classe = classe
        self.forca = forca
        self.defesa = defesa
        self.vida = vida

    def atacar(self, outro):
        dano_base = random.randint(1, self.forca)
        dano_final = max(dano_base - outro.defesa, 0)
        outro.vida -= dano_final
        print(f"{self.nome} atacou {outro.nome} causando {dano_final} de dano!")

    def esta_vivo(self):
        return self.vida > 0

class Mago(Personagem):
    def __init__(self, nome):
        super().__init__(nome, "Mago", 5, 2, 20)

    def magia(self, outro):
        chance = random.randint(1, 4)
        if chance == 1:
            dano = 15
            outro.vida -= dano
            print(f"{self.nome} lançou uma MAGIA CRÍTICA em {outro.nome} causando {dano} de dano!")
        else:
            print(f"{self.nome} tentou lançar magia, mas falhou!")

class Guerreiro(Personagem):
    def __init__(self, nome):
        super().__init__(nome, "Guerreiro", 8, 4, 30)

    def ataque_duplo(self, outro):
        print(f"{self.nome} usou ATAQUE DUPLO!")
        for _ in range(2):
            self.atacar(outro)

class Monstro(Personagem):
    def __init__(self):
        super().__init__("Bug das Sombras", "Monstro", 7, 3, 30)

# Criando personagens com entrada do usuário
print("Bem-vindo à Batalha Interativa!")
nome_jogador = input("Digite seu nome de herói: ")

print("Escolha sua classe:")
print("1 - Guerreiro (Ataque Duplo)")
print("2 - Mago (Magia Especial)")

escolha = input("Digite 1 ou 2: ")
if escolha == "1":
    heroi = Guerreiro(nome_jogador)
else:
    heroi = Mago(nome_jogador)

inimigo = Monstro()

# Loop do jogo
rodada = 1
while heroi.esta_vivo() and inimigo.esta_vivo():
    print(f"\n--- Rodada {rodada} ---")
    print(f"Sua vida: {heroi.vida}")
    print(f"Vida do {inimigo.nome}: {inimigo.vida}")

    print("\nEscolha sua ação:")
    print("1 - Atacar")
    if isinstance(heroi, Guerreiro):
        print("2 - Ataque Duplo")
    else:
        print("2 - Magia")
    print("3 - Fugir")

    acao = input("Digite 1, 2 ou 3: ")

    if acao == "1":
        heroi.atacar(inimigo)
    elif acao == "2":
        if isinstance(heroi, Guerreiro):
            heroi.ataque_duplo(inimigo)
        else:
            heroi.magia(inimigo)
    elif acao == "3":
        print("Você fugiu da batalha! 🏃‍♂️💨")
        break
    else:
        print("Opção inválida! Perdeu a vez!")

    if inimigo.esta_vivo():
        inimigo.atacar(heroi)

    rodada += 1

# Fim do jogo
if not heroi.esta_vivo():
    print("\nVocê foi derrotado pelo Bug das Sombras! 💀")
elif not inimigo.esta_vivo():
    print(f"\nParabéns {heroi.nome}, você venceu a batalha! 🏆")